# Server configuration
PORT=5000

# Authentication
JWT_SECRET=replace_with_secure_secret

# Database
MONGO_URI=replace_with_mongodb_connection_string

# Cloudinary
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_CLOUD_NAME=

# Gemma via OpenRouter
OPENROUTER_API_KEY=
AI_MODEL=google/gemma-2-9b-it

# Optional chatbot persona
SUPPORT_BOT_NAME=EduBuddy
SUPPORT_BOT_SYSTEM_CONTEXT=You are the official EduHub LMS support assistant for students, instructors, and administrators.
